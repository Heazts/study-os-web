# Copie este arquivo para backend/.env e ajuste os valores.
# Em produção (Docker/Hugging Face Spaces), defina estas mesmas variáveis
# como env vars/secrets do ambiente em vez de usar um arquivo .env.

# Caminho do banco SQLite. Em Docker, aponte para dentro de um volume
# persistente (veja docker-compose.yml) — senão os dados somem a cada
# recriação do container.
DATABASE_URL=sqlite:///./study_os.db

# Alternativa com persistência real em hosts gratuitos de armazenamento
# efêmero (ex.: Hugging Face Spaces sem "Persistent Storage"): aponte para um
# Postgres gerenciado gratuito, como Supabase (supabase.com/database) ou Neon
# (neon.tech). Basta colar a "connection string" que eles fornecem, por ex.:
# DATABASE_URL=postgresql://usuario:senha@host:5432/nome_do_banco?sslmode=require
# O driver (psycopg2-binary) já está no requirements.txt — não precisa instalar nada a mais.

# Chave usada para assinar os tokens JWT. Gere uma chave aleatória de verdade
# com: python -c "import secrets; print(secrets.token_hex(32))"
# Se não definida, o backend gera uma chave aleatória a cada start (funciona,
# mas invalida todos os tokens emitidos antes do restart).
SECRET_KEY=

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Se definida, exige esse valor no campo "Código de convite" da tela de
# cadastro - sem isso, qualquer pessoa que encontrar a URL da API consegue
# criar conta. Recomendado pra instalação pessoal/privada. Gere um valor com:
# python -c "import secrets; print(secrets.token_urlsafe(16))"
# Se deixar em branco (padrão), o cadastro fica aberto, como antes.
REGISTRATION_CODE=

# Lista (separada por vírgula, sem espaço) de origens que podem chamar esta
# API a partir do navegador. Só precisa definir se o domínio do seu GitHub
# Pages for diferente do default já embutido em backend/app/main.py
# (heazts.github.io) - ex.: se você forkar o projeto.
# CORS_ORIGINS=https://seu-usuario.github.io,http://localhost:3000
